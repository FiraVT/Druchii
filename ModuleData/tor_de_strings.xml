    <!-- Dialog Strings -->
    <string id="druchii_dialog_01" text="My Lord! We have taken many captives from the nearby villages. They are yours to command." />
    <string id="druchii_dialog_02" text="I have need of your captives. Hand over the spoils." />
    <string id="druchii_dialog_03" text="Carry on with your work." />

    <!-- Horde Camp Strings -->
