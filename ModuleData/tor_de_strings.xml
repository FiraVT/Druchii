    <!-- Character Creation Strings -->
    <string id="str_darkelves_culture_desc" text="The Druchii, or Dark Elves, are a cruel and malevolent race of elves who inhabit the cold and desolate land of Naggaroth. Led by the Witch King Malekith, they are masters of dark magic, piracy, and slavery." />
    <string id="str_clan_name_druchii_1" text="House of Naggarond" />
    <string id="str_clan_name_druchii_2" text="House of Ghrond" />
    <string id="str_clan_name_druchii_3" text="House of Clar Karond" />
    <string id="str_clan_name_druchii_4" text="House of Karond Kar" />
    <string id="str_clan_name_druchii_5" text="House of Hag Graef" />
    <string id="tor_cc_de_option1_1_label" text="Druchii Nobility" />
    <string id="tor_cc_de_option1_1_text" text="Born into a noble house of Naggarond, you were raised with the expectation of absolute loyalty to the Witch King and absolute cruelty to your inferiors." />
    <string id="tor_cc_de_option1_2_label" text="Corsair Family" />
    <string id="tor_cc_de_option1_2_text" text="The sea is in your blood. Your family has sailed the Black Arks for generations, raiding the coasts of Ulthuan and the Old World." />
    <string id="tor_cc_de_option2_1_label" text="Coastal Raiding" />
    <string id="tor_cc_de_option2_1_text" text="You spent your youth on raiding parties, learning how to strike fast and hard, and how to secure valuable captives for the slave markets." />
    <string id="tor_cc_de_option2_2_label" text="Court Intrigue" />
    <string id="tor_cc_de_option2_2_text" text="Naggaroth is as dangerous in the courts as it is on the battlefield. You learned early on that a well-placed word or a subtle poison can be more effective than a sword." />
    <string id="tor_cc_de_option3_1_label" text="Druchii Mercenary" />
    <string id="tor_cc_de_option3_1_effect" text="Druchii Mercenary Career" />
    <string id="tor_cc_de_option3_1_text" text="You have left the service of the Dreadlords to seek your own fortune. As a mercenary, your skills are for hire to the highest bidder, though your heart remains as cold as the Naggaroth ice." />
    <string id="tor_cc_de_option3_2_label" text="Druchii Sorceress" />
    <string id="tor_cc_de_option3_2_effect" text="Druchii Sorceress Career" />
    <string id="tor_cc_de_option3_2_text" text="You have been trained in the Convent of Sorceresses. You wield the dark winds of magic with terrifying precision, a power reserved strictly for the females of your race." />

    <!-- Custom Resources -->
    <string id="tor_custom_resource_name.Slaves" text="Slaves" />
    <string id="tor_custom_resource_description.Slaves" text="Slaves are the lifeblood of the Druchii economy. They are captured in battle and used for labor, sacrifice, and as a currency among the Dark Elves." />
    <string id="tor_custom_resource_slaves_count" text="Current Slaves" />

    <!-- Companion Name Strings -->
    <string id="str_tor_wanderer_druchii_sorceress_dark_0" text="{FIRSTNAME} the Dark Sorceress" />
    <string id="str_tor_wanderer_druchii_sorceress_fire_0" text="{FIRSTNAME} the Fire Sorceress" />

    <!-- Dark Sorceress Strings -->
    <string id="tor_introduction.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_intro_de_sorc_dark}Greetings, worm. You look like you could use the guidance of one who has mastered the winds of Dhar." />
    <string id="tor_prebackstory.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_preback_de_sorc_dark}You wish to know my story? Knowledge is a dangerous thing, but if you insist..." />
    <string id="tor_backstory_a.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_back_a_de_sorc_dark}I was born in Naggarond, the City of Cold, where only the strongest survive and the weak are but fodder for the sacrificial altars." />
    <string id="tor_backstory_b.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_back_b_de_sorc_dark}I spent decades in the Ghrond, learning to twist the winds of magic to my will under the watchful eyes of the Convent." />
    <string id="tor_backstory_c.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_back_c_de_sorc_dark}My rivals thought they could exile me to these primitive lands. They were wrong. I am merely expanding my influence and seeking new sources of power." />
    <string id="tor_backstory_d.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_back_d_de_sorc_dark}I am a Sorceress of the Druchii. My magic can wither the souls of your enemies and leave them as empty husks." />
    <string id="tor_hire_companion_payment.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_payment_de_sorc_dark}My services are not for the destitute. I shall require {GOLD_AMOUNT}{GOLD_ICON} to compensate for my time." />

    <!-- Fire Sorceress Strings -->
    <string id="tor_introduction.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_intro_de_sorc_fire}Be careful where you step. The air around me is prone to... spontaneous combustion when my temper flares." />
    <string id="tor_prebackstory.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_preback_de_sorc_fire}My past is written in ash and flame. Do you truly wish to hear it?" />
    <string id="tor_backstory_a.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_back_a_de_sorc_fire}Fire is the purest of elements. It cleanses the weak and empowers those with the will to command it." />
    <string id="tor_backstory_b.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_back_b_de_sorc_fire}In the shadows of the Iron Mountains, I mastered the flame. It spoke to me of destruction and the glory of Khaine." />
    <string id="tor_backstory_c.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_back_c_de_sorc_fire}I seek to burn the enemies of Naggaroth, and perhaps a few others who are foolish enough to cross my path." />
    <string id="tor_backstory_d.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_back_d_de_sorc_fire}I am a Mistress of the Lore of Fire. Together, we shall leave nothing but cinders in our wake." />
    <string id="tor_hire_companion_payment.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_payment_de_sorc_fire}The cost of such power is {GOLD_AMOUNT}{GOLD_ICON}. A small price to pay for the sun's own fury." />

    <!-- Shared/Generic Strings -->
    <string id="tor_hire_companion_tell_me_p.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_tell_me_de_sorc}Tell me of your path, Sorceress." />
    <string id="tor_hire_companion_tell_me_p.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_tell_me_de_sorc_f}Tell me of your path, Sorceress." />
    <string id="tor_response_1.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_resp_1_de_sorc}Continue." />
    <string id="tor_response_1.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_resp_1_de_sorc_f}Continue." />
    <string id="tor_response_2.tor_wanderer_druchii_sorceress_dark_0" text="{=str_tor_resp_2_de_sorc}I see." />
    <string id="tor_response_2.tor_wanderer_druchii_sorceress_fire_0" text="{=str_tor_resp_2_de_sorc_f}I see." />
