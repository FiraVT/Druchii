<?xml version="1.0" encoding="utf-8"?>
<AbilityTemplates>
    <!-- Kindleflame - Fire Sorceress Passive -->
    <AbilityTemplate StringID="Kindleflame"
                     Name="{=kindleflame_label_str}Kindleflame"
                     SpriteName="firemagic_symbol"
                     CoolDown="0"
                     WindsOfMagicCost="0"
                     Duration="15"
                     AbilityType="CareerAbility"
                     AbilityEffectType="Augment"
                     TriggerType="TickOnce"
                     CastType="Instant"
                     AbilityTargetType="Self"
                     CrosshairType="Self"
                     TooltipDescription="{=kindleflame_description_str}Fire feeds fire, two blazes together are stronger and hotter than two apart. Casting Lore of Fire spells intensifies the heat, making all enemies across the battlefield 20% more vulnerable to fire damage for 15 seconds.">
    </AbilityTemplate>

