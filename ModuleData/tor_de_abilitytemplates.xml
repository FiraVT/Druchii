                     Duration="90"
                     AbilityType="CareerAbility"
                     AbilityEffectType="Augment"
                     TriggerType="TickOnce"
                     CastType="Instant"
                     AbilityTargetType="Self"
                     CrosshairType="Self"
                     TooltipDescription="{=murderous_prowess_label_str}The Dark Elves' thirst for slaughter is insatiable. Once enough blood has been spilled on the battlefield, the Druchii enter a state of murderous frenzy, significantly increasing their combat prowess for a duration.">
        <TriggeredEffect>de_murderous_prowess_trigger</TriggeredEffect>
    </AbilityTemplate>

