    <StatusEffectTemplate 
        id="de_doomfire_poison_mov_debuff" 
        type="MovementManipulation" 
        base_effect_value="-0.25" />

    <StatusEffectTemplate 
        id="de_doomfire_poison_dmg_debuff" 
        type="DamageAmplification" 
        damage_type="Physical" 
        base_effect_value="-0.15" />

