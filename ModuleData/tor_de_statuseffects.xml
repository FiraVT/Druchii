    <StatusEffectTemplate id="de_madness_of_khaine_ats" type="AttackSpeedManipulation" base_effect_value="0.20" />
    <StatusEffectTemplate id="de_madness_of_khaine_res" type="Resistance" damage_type="All" base_effect_value="-0.20" />

    <!-- Kindleflame Weakness -->
